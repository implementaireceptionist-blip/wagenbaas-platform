# ════════════════════════════════════════════════
#   WAGENBAAS OMNICHANNEL AI RECEPTIONIST
#   Zet een kanaal AAN/UIT met true/false
# ════════════════════════════════════════════════

# ── AI MODEL ─────────────────────────────────────
# gemini  → Google Gemini 2.5 Flash (GRATIS, demo)
# haiku   → Claude Haiku (betaald, productie)
AI_PROVIDER=haiku
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── SERVER ────────────────────────────────────────
PORT=3000
ALLOWED_ORIGIN=*
ADMIN_TOKEN=wagenbaas-admin-2024

# ── KANALEN ON/OFF ────────────────────────────────
ENABLE_WEBCHAT=true
ENABLE_SMS=false
ENABLE_EMAIL=false
ENABLE_WHATSAPP=false
ENABLE_FACEBOOK=false
ENABLE_INSTAGRAM=false
ENABLE_VOICE=false       # Telnyx PSTN (old)
ENABLE_VOICE_AGENT=false # Twilio + Deepgram Voice Agent (NEW — zet op true)
ENABLE_TIKTOK=false

# ── SMS (Telnyx) ──────────────────────────────────
# Account: telnyx.com → gratis $20 credit bij signup
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PHONE_NUMBER=+31XXXXXXXXXX

# ── EMAIL (Mailgun) ───────────────────────────────
# Account: mailgun.com → 1000 emails/maand gratis
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_USER=postmaster@jouwdomein.mailgun.org
MAILGUN_SMTP_PASS=your_mailgun_password
EMAIL_FROM=Wagenbaas Receptionist <receptionist@wagenbaas.nl>
EMAIL_OWNER=info@wagenbaas.nl

# ── WHATSAPP (Meta Cloud API) ─────────────────────
# Account: developers.facebook.com → gratis inbound
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=wagenbaas_verify_2024

# ── FACEBOOK MESSENGER ────────────────────────────
FACEBOOK_PAGE_TOKEN=your_page_access_token
FACEBOOK_VERIFY_TOKEN=wagenbaas_fb_verify_2024
FACEBOOK_APP_SECRET=your_app_secret

# ── INSTAGRAM DM ─────────────────────────────────
# Zelfde app als Facebook (Instagram Basic Display API)
INSTAGRAM_PAGE_TOKEN=your_instagram_token
INSTAGRAM_VERIFY_TOKEN=wagenbaas_ig_verify_2024

# ── VOICE AGENT (Twilio + Deepgram — AANBEVOLEN) ─
# Stap 1: Maak gratis Deepgram account → console.deepgram.com ($200 credit)
DEEPGRAM_API_KEY=0697ef8f9f14af53da995222358184e7159000c5
#
# Stap 2: Maak gratis Twilio account → twilio.com (koop een nummer ~$1/maand)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
#
# Stap 3: Zet Twilio webhook op POST https://jouwdomein.com/api/twilio/voice
# Stap 4: Doorstuur +40752859831 naar Twilio nummer via: *21*+1XXXXXXXXXX#
#
# ── Deepgram Voice Agent model configuratie ───────
# STT: nova-3 (multi-taal NL/EN/DE/FR) | flux (50% sneller, Engels)
DEEPGRAM_AGENT_STT_MODEL=nova-3
# LLM: Anthropic Claude (Haiku = snelst + goedkoopst)
DEEPGRAM_AGENT_LLM_MODEL=claude-haiku-4-5-20251001
# TTS: Deepgram Aura-2 (sub-200ms) — andere opties: aura-2-luna-en, aura-2-orion-en
DEEPGRAM_AGENT_TTS_MODEL=aura-2-thalia-en
# Temperature: 0.3 = consistent, 0.7 = creatiever
DEEPGRAM_AGENT_TEMPERATURE=0.3
# Begroeting die de AI als eerste zegt
VOICE_AGENT_GREETING=Goedendag, u bent verbonden met Wagenbaas. Hoe kan ik u helpen?
# Optioneel: overschrijf het agent-prompt volledig (leeg = standaard prompt)
VOICE_AGENT_PROMPT=

# ── TIKTOK (Beta) ─────────────────────────────────
TIKTOK_ACCESS_TOKEN=your_tiktok_token
TIKTOK_VERIFY_TOKEN=wagenbaas_tt_verify_2024
